# MySQL
DATABASE_URL=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-mysql-password
MYSQL_DATABASE=llm_ppt_generator

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# LLM / Embedding
LLM_PROVIDER=qwen_native
CHAT_MODEL_NAME=qwen3-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY_ENV=DASHSCOPE_API_KEY
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL_NAME=text-embedding-v4
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
OPENAI_API_KEY=replace-with-your-openai-compatible-api-key

# RAG
CHROMA_COLLECTION_NAME=rag
CHROMA_PERSIST_DIRECTORY=chroma_db
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=120
RAG_MAX_SPLIT_CHAR_NUMBER=1000
RETRIEVAL_TOP_K=5

# Image APIs, optional
PEXELS_API_KEY=replace-with-your-pexels-api-key
UNSPLASH_ACCESS_KEY=replace-with-your-unsplash-access-key

# Business defaults
DEFAULT_PAGE_COUNT=8
MIN_PAGE_COUNT=3
MAX_PAGE_COUNT=20
DEFAULT_LANGUAGE=中文
DEFAULT_PPT_COST_PER_PAGE=10
